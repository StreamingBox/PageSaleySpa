<!-- NAVBAR -->
<nav class="site-nav">
    <div class="logo">SaleySpa</div>

    <div class="nav-menu" id="nav-menu">
        <a href="/"           class="nav-link <%= path === '/' ? 'active' : '' %>">Inicio</a>
        <a href="/clients"    class="nav-link <%= path === '/clients' ? 'active' : '' %>">Clientes</a>
        <a href="/products"   class="nav-link <%= path === '/products' ? 'active' : '' %>">Productos</a>
        <a href="/sales"      class="nav-link <%= path === '/sales' ? 'active' : '' %>">Ventas</a>
        <a href="/movements"  class="nav-link <%= path === '/movements' ? 'active' : '' %>">Movimientos</a>
        <a href="/reports"    class="nav-link <%= path === '/reports' ? 'active' : '' %>">Reportes</a>
        <a href="/logout"     class="nav-link">Salir</a>
    </div>

    <div id="hamburger" class="hamburger-icon">
        <!-- icono opcional -->
    </div>
</nav>

<script>
    const burger = document.getElementById('hamburger');
    const menu   = document.getElementById('nav-menu');

    burger.addEventListener('click', () => {
        burger.classList.toggle('active');
        menu.classList.toggle('active');
    });

    document.addEventListener('click', (e) => {
        if (!menu.contains(e.target) && !burger.contains(e.target)) {
            burger.classList.remove('active');
            menu.classList.remove('active');
        }
    });
</script>
