<style>
    *, *::before, *::after {
        box-sizing: border-box;
    }

    :root {
        --bg: #f7f1e3;
        --bg-soft: rgba(255, 255, 255, 0.52);
        --card: rgba(253, 249, 239, 0.92);
        --card-edge: rgba(181, 149, 208, 0.26);
        --text: #76568d;
        --muted: #9f8ca8;
        --input-bg: rgba(255, 255, 255, 0.9);
        --input-border: rgba(177, 154, 190, 0.36);
        --button-shadow: rgba(157, 116, 186, 0.34);
        --button-text: #fffdfd;
        --danger-bg: rgba(215, 84, 108, 0.12);
        --danger-text: #b24560;
        --field-shadow: 0 10px 18px rgba(122, 95, 139, 0.18);
        --card-shadow: 0 28px 60px rgba(128, 103, 145, 0.18);
        --ornament-a: rgba(232, 205, 235, 0.88);
        --ornament-b: rgba(216, 233, 216, 0.75);
        --ornament-c: rgba(250, 220, 228, 0.82);
    }

    html[data-theme='dark'] {
        --bg: #241c31;
        --bg-soft: rgba(64, 48, 82, 0.42);
        --card: rgba(43, 33, 57, 0.9);
        --card-edge: rgba(211, 186, 231, 0.2);
        --text: #efe4f5;
        --muted: #cabbd2;
        --input-bg: rgba(255, 255, 255, 0.07);
        --input-border: rgba(223, 204, 236, 0.18);
        --button-shadow: rgba(120, 84, 145, 0.32);
        --button-text: #fffdfd;
        --danger-bg: rgba(236, 118, 146, 0.16);
        --danger-text: #ffb5c6;
        --field-shadow: 0 10px 18px rgba(26, 18, 36, 0.18);
        --card-shadow: 0 28px 60px rgba(20, 12, 30, 0.24);
        --ornament-a: rgba(145, 112, 179, 0.3);
        --ornament-b: rgba(129, 158, 138, 0.2);
        --ornament-c: rgba(187, 122, 153, 0.22);
    }

    html, body {
        min-height: 100%;
        margin: 0;
    }

    body {
        color: var(--text);
        background:
            radial-gradient(circle at top left, rgba(255, 255, 255, 0.75), transparent 34%),
            radial-gradient(circle at bottom right, rgba(232, 194, 214, 0.22), transparent 28%),
            linear-gradient(180deg, var(--bg), #f4ecd8 100%);
        display: grid;
        place-items: center;
        padding: 12px;
        overflow-x: hidden;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    html[data-theme='dark'] body {
        background:
            radial-gradient(circle at top left, rgba(128, 103, 156, 0.28), transparent 34%),
            radial-gradient(circle at bottom right, rgba(151, 101, 129, 0.16), transparent 28%),
            linear-gradient(180deg, var(--bg), #1e1729 100%);
    }

    .theme-toggle {
        position: fixed;
        top: 14px;
        right: 14px;
        z-index: 3;
        width: 42px;
        height: 42px;
        border: 1px solid var(--card-edge);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.52);
        color: var(--text);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        backdrop-filter: blur(8px);
        box-shadow: 0 10px 18px rgba(126, 103, 138, 0.15);
    }

    html[data-theme='dark'] .theme-toggle {
        background: rgba(62, 47, 79, 0.62);
        box-shadow: 0 10px 18px rgba(22, 14, 31, 0.18);
    }

    .theme-toggle svg {
        width: 18px;
        height: 18px;
    }

    .theme-toggle .icon-sun {
        display: none;
    }

    html[data-theme='dark'] .theme-toggle .icon-sun {
        display: block;
    }

    html[data-theme='dark'] .theme-toggle .icon-moon {
        display: none;
    }

    .auth-shell {
        width: min(100%, 480px);
        min-height: calc(100vh - 24px);
        position: relative;
        display: flex;
        align-items: stretch;
    }

    .auth-shell::before,
    .auth-shell::after,
    .auth-card::before,
    .auth-card::after {
        content: '';
        position: absolute;
        pointer-events: none;
    }

    .auth-shell::before {
        inset: 10px 8px auto auto;
        width: 108px;
        height: 108px;
        border-radius: 38% 62% 58% 42%;
        background:
            radial-gradient(circle at 62% 30%, rgba(255, 238, 173, 0.75), transparent 18%),
            radial-gradient(circle at 66% 36%, rgba(255, 216, 228, 0.9), transparent 44%),
            radial-gradient(circle at 22% 70%, rgba(204, 221, 194, 0.82), transparent 26%);
        opacity: 0.9;
        filter: blur(0.5px);
    }

    .auth-shell::after {
        inset: auto auto 22px -10px;
        width: 124px;
        height: 124px;
        border-radius: 50% 50% 30% 70%;
        background:
            radial-gradient(circle at 28% 38%, rgba(240, 206, 228, 0.95), transparent 42%),
            radial-gradient(circle at 72% 76%, rgba(233, 224, 194, 0.9), transparent 20%),
            radial-gradient(circle at 68% 72%, rgba(205, 224, 196, 0.82), transparent 40%);
        opacity: 0.88;
    }

    .auth-card {
        width: 100%;
        position: relative;
        overflow: hidden;
        display: grid;
        align-content: start;
        gap: 14px;
        padding: 28px 28px 24px;
        border: 1px solid var(--card-edge);
        border-radius: 30px;
        background:
            radial-gradient(circle at top center, rgba(255, 255, 255, 0.65), transparent 24%),
            linear-gradient(180deg, var(--card), rgba(255, 249, 236, 0.94));
        box-shadow: var(--card-shadow);
        backdrop-filter: blur(12px);
    }

    html[data-theme='dark'] .auth-card {
        background:
            radial-gradient(circle at top center, rgba(255, 255, 255, 0.06), transparent 26%),
            linear-gradient(180deg, var(--card), rgba(35, 27, 46, 0.94));
    }

    .auth-card::before {
        inset: 12px;
        border: 1px solid rgba(179, 152, 202, 0.22);
        border-radius: 24px;
    }

    .auth-card::after {
        inset: auto 20px 14px auto;
        width: 92px;
        height: 44px;
        background:
            radial-gradient(circle at 18% 58%, rgba(255, 255, 255, 0.95), transparent 22%),
            radial-gradient(circle at 44% 50%, rgba(226, 200, 228, 0.95), transparent 28%),
            radial-gradient(circle at 72% 52%, rgba(214, 185, 224, 0.92), transparent 24%);
        opacity: 0.55;
        transform: rotate(-7deg);
    }

    .brand,
    .auth-copy,
    .alert,
    .form,
    .auth-links,
    .bottom-flourish {
        position: relative;
        z-index: 1;
    }

    .brand {
        text-align: center;
        padding-top: 16px;
        padding-bottom: 8px;
    }

    .brand img {
        width: 90%;
        max-width: 400px;
        height: auto;
        display: block;
        margin: 0 auto;
        filter: drop-shadow(0 12px 24px rgba(170, 135, 188, 0.16));
    }

    .brand-bloom {
        position: absolute;
        inset: -10px 0 auto;
        display: flex;
        justify-content: center;
        gap: 56px;
        opacity: 0.58;
    }

    .brand-bloom span {
        width: 28px;
        height: 28px;
        display: block;
        border-radius: 50% 0 50% 50%;
        transform: rotate(35deg);
        background: linear-gradient(135deg, var(--ornament-a), var(--ornament-c));
        box-shadow: 20px -8px 0 -6px var(--ornament-b), -18px 14px 0 -7px var(--ornament-c);
    }

    .auth-copy {
        text-align: center;
        display: grid;
        gap: 8px;
    }

    .auth-copy h1 {
        margin: 0;
        color: #845b98;
        font-family: 'Manrope', sans-serif;
        font-size: clamp(2rem, 7vw, 2.35rem);
        font-weight: 600;
        letter-spacing: -0.04em;
    }

    html[data-theme='dark'] .auth-copy h1 {
        color: #f1e4f7;
    }

    .auth-copy p {
        margin: 0;
        color: var(--muted);
        font-size: 0.95rem;
        line-height: 1.55;
    }

    .alert {
        padding: 12px 14px;
        border-radius: 16px;
        background: var(--danger-bg);
        color: var(--danger-text);
        font-size: 0.92rem;
        text-align: center;
    }

    .form {
        display: grid;
        gap: 12px;
    }

    .form-item {
        display: grid;
        gap: 8px;
    }

    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }

    .input-shell {
        position: relative;
    }

    .field-icon,
    .btn-eye {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        color: #b5a8b8;
    }

    .field-icon {
        left: 16px;
        width: 20px;
        height: 20px;
        pointer-events: none;
    }

    .btn-eye {
        right: 14px;
        width: 28px;
        height: 28px;
        border: 0;
        background: transparent;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        cursor: pointer;
    }

    .btn-eye svg {
        width: 18px;
        height: 18px;
    }

    .btn-eye .eye-off {
        display: none;
    }

    .btn-eye.is-active .eye-on {
        display: none;
    }

    .btn-eye.is-active .eye-off {
        display: block;
    }

    .form input {
        width: 100%;
        height: 58px;
        border: 1px solid var(--input-border);
        border-radius: 14px;
        background: var(--input-bg);
        color: var(--text);
        padding: 0 50px 0 48px;
        font: inherit;
        font-size: 0.98rem;
        box-shadow: var(--field-shadow);
        outline: none;
        transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
    }

    .form input::placeholder {
        color: #b7afb7;
    }

    .form input:focus {
        border-color: rgba(177, 132, 201, 0.72);
        box-shadow: 0 14px 24px rgba(126, 95, 149, 0.2);
        transform: translateY(-1px);
    }

    .auth-btn {
        margin-top: 8px;
        width: 100%;
        height: 56px;
        border: 0;
        border-radius: 999px;
        background: linear-gradient(180deg, #b88ad0, #a978c4);
        color: var(--button-text);
        font: inherit;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        box-shadow: 0 14px 24px var(--button-shadow);
        transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
    }

    .auth-btn:hover {
        transform: translateY(-2px);
        filter: brightness(1.02);
        box-shadow: 0 18px 28px rgba(152, 112, 181, 0.4);
    }

    .remember-row {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 0 4px;
    }

    #remember-session-toggle {
        width: 100%;
    }

    .remember-toggle {
        position: relative;
        display: inline-flex;
        align-items: flex-start;
        gap: 10px;
        width: 100%;
        color: var(--muted);
        font-size: 0.92rem;
        line-height: 1.25;
        cursor: pointer;
        user-select: none;
    }

    .remember-toggle__button {
        position: relative;
        flex: 0 0 16px;
        width: 16px;
        height: 16px;
        margin: 2px 0 0;
        padding: 0;
        border: 1px solid rgba(169, 120, 196, 0.52);
        border-radius: 5px;
        background: rgba(255, 255, 255, 0.92);
        box-shadow: 0 4px 10px rgba(156, 126, 181, 0.12);
        cursor: pointer;
        transition:
            background 0.18s ease,
            border-color 0.18s ease,
            box-shadow 0.18s ease,
            transform 0.18s ease;
    }

    .remember-toggle__button:hover {
        border-color: rgba(169, 120, 196, 0.78);
        transform: translateY(-1px);
    }

    .remember-toggle__button:focus-visible {
        outline: 0;
        border-color: rgba(169, 120, 196, 0.92);
        box-shadow:
            0 0 0 3px rgba(169, 120, 196, 0.16),
            0 6px 14px rgba(156, 126, 181, 0.16);
    }

    .remember-toggle__button--checked {
        border-color: transparent;
        background: linear-gradient(180deg, #bb8dd1, #a978c4);
        box-shadow: 0 8px 16px rgba(153, 112, 183, 0.22);
    }

    .remember-toggle__mark {
        position: absolute;
        left: 5px;
        top: 2px;
        width: 4px;
        height: 8px;
        border: solid #ffffff;
        border-width: 0 2px 2px 0;
        opacity: 0;
        transform: rotate(45deg) scale(0.75);
        transition: opacity 0.18s ease, transform 0.18s ease;
    }

    .remember-toggle__button--checked .remember-toggle__mark {
        opacity: 1;
        transform: rotate(45deg) scale(1);
    }

    .remember-toggle__native {
        position: absolute;
        opacity: 0;
        pointer-events: none;
    }

    .remember-toggle__text {
        flex: 1;
    }

    .auth-links {
        display: grid;
        justify-items: center;
        gap: 12px;
        padding-top: 4px;
    }

    .auth-links a,
    .auth-links span {
        color: #8f76a0;
        text-decoration: none;
        font-size: 0.98rem;
    }

    .auth-links a:hover {
        text-decoration: underline;
    }

    .auth-links .secondary-link {
        font-weight: 500;
    }

    .auth-links .register-link {
        font-weight: 600;
    }

    .bottom-flourish {
        height: 52px;
        margin-top: 4px;
    }

    .bottom-flourish::before,
    .bottom-flourish::after {
        content: '';
        position: absolute;
        inset: auto;
    }

    .bottom-flourish::before {
        left: 6px;
        bottom: 4px;
        width: 88px;
        height: 42px;
        background:
            radial-gradient(circle at 18% 60%, rgba(236, 198, 225, 0.92), transparent 24%),
            radial-gradient(circle at 36% 42%, rgba(241, 212, 231, 0.88), transparent 28%),
            radial-gradient(circle at 62% 78%, rgba(211, 223, 203, 0.82), transparent 26%);
        opacity: 0.8;
    }

    .bottom-flourish::after {
        right: 8px;
        bottom: 0;
        width: 86px;
        height: 36px;
        background:
            radial-gradient(circle at 22% 52%, rgba(253, 248, 241, 0.95), transparent 16%),
            radial-gradient(circle at 48% 52%, rgba(236, 220, 210, 0.96), transparent 20%),
            radial-gradient(circle at 72% 52%, rgba(220, 184, 233, 0.92), transparent 24%);
        opacity: 0.72;
    }

    @media (min-width: 720px) {
        body {
            padding: 24px;
        }

        .auth-shell {
            width: min(100%, 640px);
            min-height: auto;
        }

        .auth-card {
            padding: 34px 30px 28px;
        }
    }

    @media (max-width: 480px) {
        body {
            padding: 8px;
        }

        .auth-shell {
            width: 100%;
        }

        .auth-card {
            padding: 24px 16px 20px;
            gap: 12px;
            border-radius: 24px;
        }

        .brand img {
            width: 85%;
            max-width: 320px;
        }

        .form input {
            height: 52px;
            padding: 0 44px 0 42px;
        }

        .auth-btn {
            height: 50px;
            font-size: 0.95rem;
        }

        .auth-links a,
        .auth-links span {
            font-size: 0.9rem;
        }

        .bottom-flourish {
            height: 36px;
        }
    }
</style>
