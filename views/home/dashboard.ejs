<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Dashboard</title>

    <!-- Hojas de estilo -->
    <link rel="stylesheet" href="/css/styleClients.css">
    <link rel="stylesheet" href="/css/styleDashboard.css">
    <link rel="stylesheet" href="/css/styleNav.css"><!-- menú -->
</head>
<body>

<!-- ===== NAVBAR ===== -->
<nav>
    <div class="logo">SaleySpa</div>

    <button id="burger" class="hamburger" aria-label="Menú">
        <span></span><span></span><span></span>
    </button>

    <aside id="nav-menu" class="nav-menu">
        <a href="/">Inicio</a>
        <a href="/clients">Clientes</a>
        <a href="/products">Productos</a>
        <a href="/sales">Ventas</a>
        <a href="/logout">Salir</a>
    </aside>
</nav>

<!-- ===== CONTENIDO ===== -->
<div class="container">
    <h1>Resumen General</h1>

    <!-- ---------- FILTRO DE FECHAS ---------- -->
    <form class="actions" method="get" action="/">
        <div class="form-group">
            <label>Desde</label>
            <input type="date" name="start" value="<%= startISO %>" required>
        </div>
        <div class="form-group">
            <label>Hasta</label>
            <input type="date" name="end" value="<%= endISO %>" required>
        </div>
        <button class="btn new-client">Filtrar</button>

        <!-- exportar -->
        <a class="btn new-client"
           style="background:#5a0ca1;margin-left:.8rem"
           href="/export?start=<%= startISO %>&end=<%= endISO %>">
            Exportar&nbsp;Excel
        </a>
    </form>

    <!-- ---------- TARJETAS KPI ---------- -->
    <div class="cards">
        <div class="card">
            <h2>Últimos 30 días</h2>
            <p class="big"><%= lastTotal %></p>
            <p><%= lastCount %> ventas</p>
        </div>

        <div class="card">
            <h2>Mes anterior</h2>
            <p class="big"><%= prevTotal %></p>
            <p><%= prevCount %> ventas</p>
        </div>

        <div class="card">
            <h2>Comparación</h2>
            <p class="big <%= diff >= 0 ? 'up' : 'down' %>">
                <% if (pct === 0 && prevTotal === '$0') { %>
                    —            <!-- cuando no hay periodo anterior -->
                <% } else { %>
                    <%= diff >= 0 ? '▲' : '▼' %> <%= pct %> %
                <% } %>
            </p>
            <p>vs mes anterior</p>
        </div>

    </div>

    <!-- ---------- PENDIENTES ---------- -->
    <h2>Clientes con saldo pendiente</h2>
    <table class="clients-table">
        <thead>
        <tr>
            <th>Cliente</th>
            <th>Teléfono</th>
            <th>Deuda</th>
        </tr>
        </thead>
        <tbody>
        <% if (!pendings.length) { %>
            <tr>
                <td colspan="3" class="text-center">Sin deudas 😊</td>
            </tr>
        <% } else { pendings.forEach(p => { %>
            <tr>
                <td><%= p.name %></td>
                <td><%= p.phone %></td>
                <td><%= money(p.debt) %></td>
            </tr>
        <% }) } %>
        </tbody>
    </table>
</div>

<!-- ===== SCRIPT MENÚ ===== -->
<script>
    const burger = document.getElementById('burger');
    const menu = document.getElementById('nav-menu');

    burger.addEventListener('click', () => {
        burger.classList.toggle('active');
        menu.classList.toggle('active');
    });

    document.addEventListener('click', e => {
        if (!menu.contains(e.target) && !burger.contains(e.target)) {
            burger.classList.remove('active');
            menu.classList.remove('active');
        }
    });
</script>
</body>
</html>
