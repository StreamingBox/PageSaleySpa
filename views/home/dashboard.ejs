<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Dashboard</title>

    <!-- estilos globales -->
    <link rel="stylesheet" href="/css/styleClients.css">
    <link rel="stylesheet" href="/css/styleDashboard.css">
    <link rel="stylesheet" href="/css/styleNav.css">

    <!-- Flatpickr CSS -->
    <link
            rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css"
    >
    <link
            rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/flatpickr/dist/themes/material_blue.css"
    >
</head>
<body>
<nav>
    <div class="logo">SaleySpa</div>
    <button id="burger" class="hamburger" aria-label="Menú">
        <span></span><span></span><span></span>
    </button>
    <aside id="nav-menu" class="nav-menu">
        <a href="/">Inicio</a>
        <a href="/clients">Clientes</a>
        <a href="/products">Productos</a>
        <a href="/sales">Ventas</a>
        <a href="/logout">Salir</a>
    </aside>
</nav>

<div class="container">
    <h1 class="page-title">Resumen General</h1>

    <!-- FILTRO DE FECHAS, CLIENTE y ESTADO DE PAGO -->
    <form class="actions" method="get" action="/">
        <div class="form-group">
            <label>Desde</label>
            <input
                    type="text"
                    name="start"
                    class="date-picker"
                    value="<%= startFmt %>"
                    placeholder="dd/mm/yyyy"
                    required
                    readonly
            >
        </div>
        <div class="form-group">
            <label>Hasta</label>
            <input
                    type="text"
                    name="end"
                    class="date-picker"
                    value="<%= endFmt %>"
                    placeholder="dd/mm/yyyy"
                    required
                    readonly
            >
        </div>
        <div class="form-group">
            <label>Cliente</label>
            <select name="client_id">
                <option value="">Todos</option>
                <% clients.forEach(c => { %>
                    <option value="<%= c.id %>" <%= c.id == clientId ? 'selected' : '' %>>
                        <%= c.name %>
                    </option>
                <% }) %>
            </select>
        </div>
        <div class="form-group">
            <label>Estado de pago</label>
            <select name="paid">
                <option value="">Todos</option>
                <option value="1" <%= paidFilter === '1' ? 'selected' : '' %>>Pagado</option>
                <option value="0" <%= paidFilter === '0' ? 'selected' : '' %>>Pendiente</option>
            </select>
        </div>
        <button type="submit" class="btn-primary">Filtrar</button>
        <a
                class="btn-secondary"
                href="/export?start=<%= startISO %>&end=<%= endISO %>&client_id=<%= clientId %>&paid=<%= paidFilter %>"
        >Exportar Excel</a>
    </form>

    <!-- TARJETAS KPI -->
    <div class="cards">
        <div class="card">
            <h2>Últimos 30 días</h2>
            <p class="big">
                <% if (lastCount > 0) { %>
                    <%= lastTotal %>
                <% } else { %>
                    $0
                <% } %>
            </p>
            <p><%= lastCount %> ventas</p>
        </div>
        <div class="card">
            <h2>Mes anterior</h2>
            <p class="big">
                <% if (prevCount > 0) { %>
                    <%= prevTotal %>
                <% } else { %>
                    $0
                <% } %>
            </p>
            <p><%= prevCount %> ventas</p>
        </div>
        <div class="card">
            <h2>Comparación</h2>
            <p class="big <%= diff >= 0 ? 'up' : 'down' %>">
                <% if (pct === 0 && prevTotal === '$0') { %>
                    —
                <% } else { %>
                    <%= diff >= 0 ? '▲' : '▼' %> <%= pct %> %
                <% } %>
            </p>
            <p>vs mes anterior</p>
        </div>
    </div>

    <!-- PENDIENTES -->
    <h2>Clientes con saldo pendiente</h2>
    <table class="clients-table">
        <thead>
        <tr>
            <th>Cliente</th>
            <th>Teléfono</th>
            <th>Deuda</th>
        </tr>
        </thead>
        <tbody>
        <% if (!pendings.length) { %>
            <tr><td colspan="3" class="text-center">Sin deudas 😊</td></tr>
        <% } else { pendings.forEach(p => { %>
            <tr>
                <td><%= p.name %></td>
                <td><%= p.phone %></td>
                <td><%= money(p.debt) %></td>
            </tr>
        <% }) } %>
        </tbody>
    </table>
</div>

<!-- scripts -->
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/es.js"></script>
<script>
    flatpickr(".date-picker", {
        locale: "es",
        dateFormat: "d/m/Y",
        allowInput: true
    });

    const burger = document.getElementById('burger');
    const menu   = document.getElementById('nav-menu');
    burger.addEventListener('click', () => {
        burger.classList.toggle('active');
        menu.classList.toggle('active');
    });
    document.addEventListener('click', e => {
        if (!menu.contains(e.target) && !burger.contains(e.target)) {
            burger.classList.remove('active');
            menu.classList.remove('active');
        }
    });
</script>
</body>
</html>
