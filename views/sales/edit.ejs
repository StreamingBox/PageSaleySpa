<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Editar Venta / Servicio</title>
    <link rel="stylesheet" href="/css/styleNav.css">
    <link rel="stylesheet" href="/css/styleSales.css">
</head>
<body>
<!-- Navbar común sin hamburguesa -->
<%- include('../partials/navbar') %>

<div class="container edit-card">
    <h1 class="card-title">Editar Venta / Servicio</h1>

    <% if (error) { %>
        <p class="error"><%= error %></p>
    <% } %>

    <form method="post" action="/sales/<%= sale.id %>/edit" class="form-grid">
        <!-- Cliente -->
        <div class="form-group">
            <label for="client_id">Cliente</label>
            <select name="client_id" id="client_id" required>
                <% clients.forEach(c => { %>
                    <option
                            value="<%= c.id %>"
                            <%= sale.client_id == c.id ? 'selected' : '' %>>
                        <%= c.name %>
                    </option>
                <% }) %>
            </select>
        </div>

        <!-- Producto / Servicio -->
        <div class="form-group">
            <label for="product_id">Producto / Servicio</label>
            <select name="product_id" id="product_id" required>
                <% products.forEach(p => { %>
                    <option
                            value="<%= p.id %>"
                            data-price="<%= p.price %>"
                            <%= sale.product_id == p.id ? 'selected' : '' %>>
                        <%= p.name %> · $<%= Number(p.price).toLocaleString('es-CO',{minimumFractionDigits:0}) %>
                    </option>
                <% }) %>
            </select>
        </div>

        <!-- Cantidad -->
        <div class="form-group">
            <label for="quantity">Cantidad</label>
            <input
                    type="number"
                    id="quantity"
                    name="quantity"
                    value="<%= sale.quantity %>"
                    min="1"
                    required
            >
        </div>

        <!-- Precio unitario -->
        <div class="form-group">
            <label>Precio unitario</label>
            <input
                    type="text"
                    id="unit_price_show"
                    readonly
                    value="$ <%= Number(sale.unit_price).toLocaleString('es-CO',{minimumFractionDigits:0}) %>"
            >
            <input
                    type="hidden"
                    id="unit_price"
                    name="unit_price"
                    value="<%= sale.unit_price %>"
            >
        </div>

        <!-- Precio total -->
        <div class="form-group">
            <label>Precio total</label>
            <input
                    type="text"
                    id="total_price_show"
                    readonly
                    value="$ <%= Number(sale.unit_price * sale.quantity).toLocaleString('es-CO',{minimumFractionDigits:0}) %>"
            >
            <input
                    type="hidden"
                    id="total_price"
                    name="total_price"
                    value="<%= sale.unit_price * sale.quantity %>"
            >
        </div>

        <!-- Fecha de venta -->
        <div class="form-group">
            <label for="sold_at">Fecha de venta</label>
            <input
                    type="date"
                    name="sold_at"
                    id="sold_at"
                    required
                    value="<%= new Date(sale.sold_at).toISOString().slice(0,10) %>"
            />
        </div>

        <!-- Estado de pago -->
        <div class="form-group">
            <label>¿Pagado?</label>
            <div class="radio-group">
                <label>
                    <input
                            type="radio"
                            name="paid"
                            value="1"
                            <%= sale.paid ? 'checked' : '' %>
                    /> Sí
                </label>
                <label>
                    <input
                            type="radio"
                            name="paid"
                            value="0"
                            <%= !sale.paid ? 'checked' : '' %>
                    /> No
                </label>
            </div>
        </div>

        <!-- Origen de pago -->
        <div class="form-group">
            <label for="payment_source">Origen de pago</label>
            <select
                    name="payment_source"
                    id="payment_source"
                    <%= !sale.paid ? 'disabled' : '' %>
                    required
            >
                <option value="">Seleccione...</option>
                <option value="NEQUI"       <%= sale.payment_source==='NEQUI'       ? 'selected' : '' %>>NEQUI</option>
                <option value="DAVIPLATA"   <%= sale.payment_source==='DAVIPLATA'   ? 'selected' : '' %>>DAVIPLATA</option>
                <option value="EFECTIVO"    <%= sale.payment_source==='EFECTIVO'    ? 'selected' : '' %>>EFECTIVO</option>
                <option value="TRANSFIYA"   <%= sale.payment_source==='TRANSFIYA'   ? 'selected' : '' %>>TRANSFIYA</option>
                <option value="NU"          <%= sale.payment_source==='NU'          ? 'selected' : '' %>>NU</option>
            </select>
        </div>

        <!-- Botón Guardar -->
        <div class="form-group full-width">
            <button type="submit" class="btn">Guardar cambios</button>
        </div>
    </form>

    <p class="link"><a href="/sales">← Volver al listado</a></p>
</div>

<script>
    // Sincronizar precio unitario y total
    const productSelect = document.getElementById('product_id');
    const qtyInput      = document.getElementById('quantity');
    const upShow        = document.getElementById('unit_price_show');
    const upHidden      = document.getElementById('unit_price');
    const tpShow        = document.getElementById('total_price_show');
    const tpHidden      = document.getElementById('total_price');
    const paidRadios    = document.querySelectorAll('input[name="paid"]');
    const sourceSelect  = document.getElementById('payment_source');

    function updatePrices() {
        const opt   = productSelect.selectedOptions[0];
        const price = opt ? parseFloat(opt.dataset.price) : 0;
        const qty   = parseInt(qtyInput.value, 10) || 1;
        upHidden.value = price;
        upShow.value   = '$ ' + price.toLocaleString('es-CO');
        const total   = price * qty;
        tpHidden.value = total;
        tpShow.value   = '$ ' + total.toLocaleString('es-CO');
    }

    productSelect.addEventListener('change', updatePrices);
    qtyInput.addEventListener('input', updatePrices);
    updatePrices();

    // Habilitar/deshabilitar origen de pago
    paidRadios.forEach(radio => {
        radio.addEventListener('change', () => {
            if (radio.value === '0') {
                sourceSelect.disabled = true;
                sourceSelect.value    = '';
            } else {
                sourceSelect.disabled = false;
            }
        });
    });
</script>
</body>
</html>
