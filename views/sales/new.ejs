<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Registrar Venta / Servicio</title>

    <link rel="stylesheet" href="/css/styleClients.css">
    <link rel="stylesheet" href="/css/styleSales.css">
    <link rel="stylesheet" href="/css/styleNav.css">
</head>
<body>

<nav>
    <div class="logo">SaleySpa</div>
    <button id="burger" class="hamburger" aria-label="Menú">
        <span></span><span></span><span></span>
    </button>

    <aside id="nav-menu" class="nav-menu">
        <a href="/">Inicio</a>
        <a href="/clients">Clientes</a>
        <a href="/products">Productos</a>
        <a href="/sales">Ventas</a>
        <a href="/logout">Salir</a>
    </aside>
</nav>

<div class="container">
    <h1>Registrar Venta / Servicio</h1>
    <% if (error) { %><p class="error"><%= error %></p><% } %>

    <form class="form-client" method="post" action="/sales/new">
        <!-- cliente -->
        <div class="form-group">
            <label>Cliente</label>
            <select name="client_id" required>
                <option value="">-- Selecciona --</option>
                <% clients.forEach(c=>{ %>
                    <option value="<%= c.id %>"><%= c.name %></option>
                <% }) %>
            </select>
        </div>

        <!-- producto -->
        <div class="form-group">
            <label>Producto / Servicio</label>
            <select id="product" name="product_id" required>
                <option value="">-- Selecciona --</option>
                <% products.forEach(p=>{ %>
                    <option value="<%= p.id %>" data-price="<%= p.price %>">
                        <%= p.name %> · $<%= Number(p.price).toLocaleString('es-CO',{minimumFractionDigits:0}) %>
                    </option>
                <% }) %>
            </select>
        </div>

        <!-- precio -->
        <div class="form-group">
            <label>Precio</label>
            <input id="price_show" type="text" readonly placeholder="$ 0">
            <input id="price" name="price" type="hidden">
        </div>

        <!-- fecha -->
        <div class="form-group">
            <label>Fecha</label>
            <input type="date" name="sold_at" required>
        </div>

        <!-- pagado -->
        <div class="form-group">
            <label>¿Pagado?</label>
            <select id="paid" name="paid">
                <option value="1">Sí</option>
                <option value="0" selected>No</option>
            </select>
        </div>

        <!-- origen -->
        <div class="form-group">
            <label>Origen del pago</label>
            <select id="source" name="payment_source" disabled>
                <option value="PENDIENTE" selected>PENDIENTE</option>
                <option value="NEQUI">NEQUI</option>
                <option value="DAVIPLATA">DAVIPLATA</option>
                <option value="EFECTIVO">EFECTIVO</option>
                <option value="TRANSFIYA">TRANSFIYA</option>
                <option value="NU">NU</option>
            </select>
        </div>

        <button class="submit-btn">Guardar</button>
    </form>

    <p class="link"><a href="/sales">← Volver al listado</a></p>
</div>

<script>
    // menú
    const b=document.getElementById('burger'),m=document.getElementById('nav-menu');
    b.onclick=()=>{b.classList.toggle('active');m.classList.toggle('active');};
    document.addEventListener('click',e=>{
        if(!m.contains(e.target)&&!b.contains(e.target)){b.classList.remove('active');m.classList.remove('active');}
    });

    // lógica formulario
    const selProduct=document.getElementById('product');
    const show=document.getElementById('price_show');
    const hidden=document.getElementById('price');
    const selPaid=document.getElementById('paid');
    const selSource=document.getElementById('source');

    selProduct.addEventListener('change',()=>{
        const opt=selProduct.selectedOptions[0];
        if (!opt){show.value='';hidden.value='';return;}
        const price=opt.dataset.price;
        show.value='$ '+Number(price).toLocaleString('es-CO',{minimumFractionDigits:0});
        hidden.value=price;
    });

    function toggle(){ if(selPaid.value==='0'){selSource.value='PENDIENTE';selSource.disabled=true;}
    else{ if(selSource.value==='PENDIENTE') selSource.value=''; selSource.disabled=false; } }
    selPaid.addEventListener('change',toggle); toggle();
</script>
</body>
</html>
