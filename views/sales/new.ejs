<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Registrar Venta / Servicio</title>

    <link rel="stylesheet" href="/css/styleClients.css">
    <link rel="stylesheet" href="/css/styleSales.css">
    <link rel="stylesheet" href="/css/styleNav.css">
</head>
<body>

<nav>
    <div class="logo">SaleySpa</div>
    <button id="burger" class="hamburger" aria-label="Menú">
        <span></span><span></span><span></span>
    </button>
    <aside id="nav-menu" class="nav-menu">
        <a href="/">Inicio</a>
        <a href="/clients">Clientes</a>
        <a href="/products">Productos</a>
        <a href="/sales">Ventas</a>
        <form action="/logout" method="POST" style="display:inline;">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" style="background:none;border:none;padding:0;cursor:pointer;font:inherit;color:inherit;">Salir</button>
        </form>
    </aside>
</nav>

<div class="container">
    <h1>Registrar Venta / Servicio</h1>
    <% if (error) { %>
        <p class="error"><%= error %></p>
    <% } %>

    <form class="form-client" method="post" action="/sales/new">
        <!-- Cliente -->
        <div class="form-group">
            <label>Cliente</label>
            <select name="client_id" required>
                <option value="">-- Selecciona --</option>
                <% clients.forEach(c => { %>
                    <option value="<%= c.id %>"><%= c.name %></option>
                <% }) %>
            </select>
        </div>

        <!-- Producto -->
        <div class="form-group">
            <label>Producto / Servicio</label>
            <select id="product" name="product_id" required>
                <option value="">-- Selecciona --</option>
                <% products.forEach(p => { %>
                    <option
                            value="<%= p.id %>"
                            data-price="<%= p.price %>"
                    >
                        <%= p.name %> · $<%= Number(p.price).toLocaleString('es-CO',{minimumFractionDigits:0}) %>
                    </option>
                <% }) %>
            </select>
        </div>

        <!-- Cantidad -->
        <div class="form-group">
            <label>Cantidad</label>
            <input
                    id="quantity"
                    name="quantity"
                    type="number"
                    min="1"
                    value="1"
                    required
            >
        </div>

        <!-- Precio unitario -->
        <div class="form-group">
            <label>Precio unitario</label>
            <input
                    id="unit_price_show"
                    type="text"
                    readonly
                    placeholder="$ 0"
            >
            <input id="unit_price" name="unit_price" type="hidden">
        </div>

        <!-- Precio total -->
        <div class="form-group">
            <label>Precio total</label>
            <input
                    id="total_price_show"
                    type="text"
                    readonly
                    placeholder="$ 0"
            >
            <input id="total_price" name="total_price" type="hidden">
        </div>

        <!-- Fecha -->
        <div class="form-group">
            <label>Fecha</label>
            <input type="date" name="sold_at" required>
        </div>

        <!-- Pagado -->
        <div class="form-group">
            <label>¿Pagado?</label>
            <select id="paid" name="paid">
                <option value="1">Sí</option>
                <option value="0" selected>No</option>
            </select>
        </div>

        <!-- Origen del pago -->
        <div class="form-group">
            <label>Origen del pago</label>
            <select id="source" name="payment_source" disabled>
                <option value="PENDIENTE" selected>PENDIENTE</option>
                <option value="NEQUI">NEQUI</option>
                <option value="DAVIPLATA">DAVIPLATA</option>
                <option value="EFECTIVO">EFECTIVO</option>
                <option value="TRANSFIYA">TRANSFIYA</option>
                <option value="NU">NU</option>
            </select>
        </div>

        <button class="submit-btn">Guardar</button>
    </form>

    <p class="link"><a href="/sales">← Volver al listado</a></p>
</div>

<script>
    // menú
    const b = document.getElementById('burger'),
        m = document.getElementById('nav-menu');
    b.onclick = () => {
        b.classList.toggle('active');
        m.classList.toggle('active');
    };
    document.addEventListener('click', e => {
        if (!m.contains(e.target) && !b.contains(e.target)) {
            b.classList.remove('active');
            m.classList.remove('active');
        }
    });

    // Lógica de precios y cantidad
    const selProduct = document.getElementById('product');
    const qtyInput   = document.getElementById('quantity');
    const upShow     = document.getElementById('unit_price_show');
    const upHidden   = document.getElementById('unit_price');
    const tpShow     = document.getElementById('total_price_show');
    const tpHidden   = document.getElementById('total_price');
    const selPaid    = document.getElementById('paid');
    const selSource  = document.getElementById('source');

    function updatePrices() {
        const opt = selProduct.selectedOptions[0];
        const price = opt?.dataset.price
            ? parseFloat(opt.dataset.price)
            : 0;
        const qty = parseInt(qtyInput.value, 10) || 1;

        // unitario
        upShow.value   = '$ ' + price.toLocaleString('es-CO');
        upHidden.value = price;

        // total
        const total = price * qty;
        tpShow.value   = '$ ' + total.toLocaleString('es-CO');
        tpHidden.value = total;
    }

    selProduct.addEventListener('change', updatePrices);
    qtyInput.addEventListener('input', updatePrices);
    updatePrices();

    // Habilitar origen si está pagado
    function toggleSource() {
        if (selPaid.value === '0') {
            selSource.value = 'PENDIENTE';
            selSource.disabled = true;
        } else {
            if (selSource.value === 'PENDIENTE') selSource.value = '';
            selSource.disabled = false;
        }
    }
    selPaid.addEventListener('change', toggleSource);
    toggleSource();
</script>
</body>
</html>
