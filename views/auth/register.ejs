<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SaleySpa | Registro</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/png" href="/brand/logo.png">
    <script>
        (function () {
            const key = 'saleyspa-theme';
            let theme = 'light';

            try {
                const savedTheme = localStorage.getItem(key);
                if (savedTheme === 'light' || savedTheme === 'dark') {
                    theme = savedTheme;
                } else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
                    theme = 'dark';
                }
            } catch (_error) {
                theme = 'light';
            }

            document.documentElement.dataset.theme = theme;
            document.documentElement.style.colorScheme = theme;
        })();
    </script>
    <link rel="stylesheet" href="/css/styleLogin.css">
</head>
<body>
<button class="auth-theme-toggle" type="button" data-theme-toggle aria-label="Cambiar tema">
    <span data-theme-label></span>
</button>

<main class="auth-shell">
    <section class="auth-hero">
        <div class="auth-brand">
            <img class="auth-brand__logo" src="/brand/logo.png" alt="SaleySpa">
        </div>

        <div class="auth-hero__copy">
            <h1>Registro 🌸</h1>
            <p>Completa tus datos para habilitar el acceso al sistema.</p>
        </div>

        <div class="auth-palette" aria-hidden="true">
            <span class="auth-palette__dot auth-palette__dot--lilac"></span>
            <span class="auth-palette__dot auth-palette__dot--aqua"></span>
            <span class="auth-palette__dot auth-palette__dot--rose"></span>
            <span class="auth-palette__dot auth-palette__dot--sage"></span>
        </div>
    </section>

    <section class="auth-panel">
        <div class="auth-panel__header">
            <p class="auth-eyebrow">Bienvenido</p>
            <h2>Registro</h2>
            <p class="auth-panel__hint">Completa los datos para crear el acceso.</p>
        </div>

        <% if (error) { %>
            <p class="error"><%= error %></p>
        <% } %>

        <form action="/register" method="POST" class="form">
            <div class="form-group">
                <label for="username">Nombre de usuario</label>
                <input type="text" id="username" name="username" value="<%= username %>" autocomplete="username" required>
            </div>

            <div class="form-group">
                <label for="email">Correo electrónico</label>
                <input type="email" id="email" name="email" value="<%= email %>" autocomplete="email" required>
            </div>

            <div class="form-group">
                <label for="password">Contraseña</label>
                <input type="password" id="password" name="password" autocomplete="new-password" required>
            </div>

            <div class="form-group">
                <button type="submit">Guardar acceso</button>
            </div>
        </form>

        <p class="auth-link">
            ¿Ya tienes acceso? <a href="/login">Iniciar sesión</a>
        </p>
    </section>
</main>

<script>
    (function () {
        const key = 'saleyspa-theme';
        const root = document.documentElement;
        const button = document.querySelector('[data-theme-toggle]');
        const label = document.querySelector('[data-theme-label]');

        const syncLabel = () => {
            if (!label) return;
            label.textContent = root.dataset.theme === 'dark' ? 'Claro' : 'Oscuro';
        };

        syncLabel();

        button?.addEventListener('click', () => {
            const nextTheme = root.dataset.theme === 'dark' ? 'light' : 'dark';
            root.dataset.theme = nextTheme;
            root.style.colorScheme = nextTheme;

            try {
                localStorage.setItem(key, nextTheme);
            } catch (_error) {
                // Ignore storage access failures.
            }

            syncLabel();
        });
    })();
</script>
</body>
</html>
