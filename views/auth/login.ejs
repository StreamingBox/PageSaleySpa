<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SaleySpa | Iniciar sesión</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/png" href="/brand/logo.png">
    <script>
        (function () {
            const key = 'saleyspa-theme';
            let theme = 'light';
            try {
                const saved = localStorage.getItem(key);
                if (saved === 'light' || saved === 'dark') theme = saved;
                else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) theme = 'dark';
            } catch (_) {}
            document.documentElement.dataset.theme = theme;
        })();
    </script>
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
        }

        :root {
            --bg: #f7f1e3;
            --bg-soft: rgba(255, 255, 255, 0.52);
            --card: rgba(253, 249, 239, 0.92);
            --card-edge: rgba(181, 149, 208, 0.26);
            --text: #76568d;
            --muted: #9f8ca8;
            --input-bg: rgba(255, 255, 255, 0.9);
            --input-border: rgba(177, 154, 190, 0.36);
            --button: #b184c9;
            --button-shadow: rgba(157, 116, 186, 0.34);
            --button-text: #fffdfd;
            --danger-bg: rgba(215, 84, 108, 0.12);
            --danger-text: #b24560;
            --field-shadow: 0 10px 18px rgba(122, 95, 139, 0.18);
            --card-shadow: 0 28px 60px rgba(128, 103, 145, 0.18);
            --ornament-a: rgba(232, 205, 235, 0.88);
            --ornament-b: rgba(216, 233, 216, 0.75);
            --ornament-c: rgba(250, 220, 228, 0.82);
        }

        html[data-theme='dark'] {
            --bg: #241c31;
            --bg-soft: rgba(64, 48, 82, 0.42);
            --card: rgba(43, 33, 57, 0.9);
            --card-edge: rgba(211, 186, 231, 0.2);
            --text: #efe4f5;
            --muted: #cabbd2;
            --input-bg: rgba(255, 255, 255, 0.07);
            --input-border: rgba(223, 204, 236, 0.18);
            --button: #bc92d5;
            --button-shadow: rgba(120, 84, 145, 0.32);
            --button-text: #fffdfd;
            --danger-bg: rgba(236, 118, 146, 0.16);
            --danger-text: #ffb5c6;
            --field-shadow: 0 10px 18px rgba(26, 18, 36, 0.18);
            --card-shadow: 0 28px 60px rgba(20, 12, 30, 0.24);
            --ornament-a: rgba(145, 112, 179, 0.3);
            --ornament-b: rgba(129, 158, 138, 0.2);
            --ornament-c: rgba(187, 122, 153, 0.22);
        }

        html, body {
            min-height: 100%;
            margin: 0;
        }

        body {
            color: var(--text);
            background:
                radial-gradient(circle at top left, rgba(255, 255, 255, 0.75), transparent 34%),
                radial-gradient(circle at bottom right, rgba(232, 194, 214, 0.22), transparent 28%),
                linear-gradient(180deg, var(--bg), #f4ecd8 100%);
            font-family: 'Plus Jakarta Sans', sans-serif;
            display: grid;
            place-items: center;
            padding: 12px;
            overflow-x: hidden;
        }

        html[data-theme='dark'] body {
            background:
                radial-gradient(circle at top left, rgba(128, 103, 156, 0.28), transparent 34%),
                radial-gradient(circle at bottom right, rgba(151, 101, 129, 0.16), transparent 28%),
                linear-gradient(180deg, var(--bg), #1e1729 100%);
        }

        .theme-toggle {
            position: fixed;
            top: 14px;
            right: 14px;
            width: 42px;
            height: 42px;
            border: 1px solid var(--card-edge);
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.52);
            color: var(--text);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            backdrop-filter: blur(8px);
            box-shadow: 0 10px 18px rgba(126, 103, 138, 0.15);
            z-index: 3;
        }

        html[data-theme='dark'] .theme-toggle {
            background: rgba(62, 47, 79, 0.62);
            box-shadow: 0 10px 18px rgba(22, 14, 31, 0.18);
        }

        .theme-toggle svg {
            width: 18px;
            height: 18px;
        }

        .theme-toggle .icon-sun {
            display: none;
        }

        html[data-theme='dark'] .theme-toggle .icon-sun {
            display: block;
        }

        html[data-theme='dark'] .theme-toggle .icon-moon {
            display: none;
        }

        .auth-shell {
            width: min(100%, 420px);
            min-height: calc(100vh - 24px);
            position: relative;
            display: flex;
            align-items: stretch;
        }

        .auth-shell::before,
        .auth-shell::after,
        .auth-card::before,
        .auth-card::after {
            content: '';
            position: absolute;
            pointer-events: none;
        }

        .auth-shell::before {
            inset: 10px 8px auto auto;
            width: 108px;
            height: 108px;
            background:
                radial-gradient(circle at 62% 30%, rgba(255, 238, 173, 0.75), transparent 18%),
                radial-gradient(circle at 66% 36%, rgba(255, 216, 228, 0.9), transparent 44%),
                radial-gradient(circle at 22% 70%, rgba(204, 221, 194, 0.82), transparent 26%);
            opacity: 0.9;
            border-radius: 38% 62% 58% 42%;
            filter: blur(0.5px);
        }

        .auth-shell::after {
            inset: auto auto 22px -10px;
            width: 124px;
            height: 124px;
            background:
                radial-gradient(circle at 28% 38%, rgba(240, 206, 228, 0.95), transparent 42%),
                radial-gradient(circle at 72% 76%, rgba(233, 224, 194, 0.9), transparent 20%),
                radial-gradient(circle at 68% 72%, rgba(205, 224, 196, 0.82), transparent 40%);
            border-radius: 50% 50% 30% 70%;
            opacity: 0.88;
        }

        .auth-card {
            width: 100%;
            position: relative;
            background:
                radial-gradient(circle at top center, rgba(255, 255, 255, 0.65), transparent 24%),
                linear-gradient(180deg, var(--card), rgba(255, 249, 236, 0.94));
            border: 1px solid var(--card-edge);
            border-radius: 30px;
            box-shadow: var(--card-shadow);
            padding: 32px 22px 28px;
            overflow: hidden;
            backdrop-filter: blur(12px);
            display: grid;
            align-content: start;
            gap: 18px;
        }

        html[data-theme='dark'] .auth-card {
            background:
                radial-gradient(circle at top center, rgba(255, 255, 255, 0.06), transparent 26%),
                linear-gradient(180deg, var(--card), rgba(35, 27, 46, 0.94));
        }

        .auth-card::before {
            inset: 12px;
            border: 1px solid rgba(179, 152, 202, 0.22);
            border-radius: 24px;
        }

        .auth-card::after {
            inset: auto 20px 14px auto;
            width: 92px;
            height: 44px;
            background:
                radial-gradient(circle at 18% 58%, rgba(255, 255, 255, 0.95), transparent 22%),
                radial-gradient(circle at 44% 50%, rgba(226, 200, 228, 0.95), transparent 28%),
                radial-gradient(circle at 72% 52%, rgba(214, 185, 224, 0.92), transparent 24%);
            opacity: 0.55;
            transform: rotate(-7deg);
        }

        .brand {
            position: relative;
            z-index: 1;
            text-align: center;
            padding-top: 8px;
        }

        .brand img {
            width: min(100%, 250px);
            height: auto;
            display: block;
            margin: 0 auto;
            filter: drop-shadow(0 10px 20px rgba(170, 135, 188, 0.14));
        }

        .brand-bloom {
            position: absolute;
            inset: -10px 0 auto;
            display: flex;
            justify-content: center;
            gap: 56px;
            opacity: 0.58;
        }

        .brand-bloom span {
            width: 28px;
            height: 28px;
            border-radius: 50% 0 50% 50%;
            display: block;
            transform: rotate(35deg);
            background: linear-gradient(135deg, var(--ornament-a), var(--ornament-c));
            box-shadow: 20px -8px 0 -6px var(--ornament-b), -18px 14px 0 -7px var(--ornament-c);
        }

        .auth-copy {
            position: relative;
            z-index: 1;
            text-align: center;
            display: grid;
            gap: 8px;
        }

        .auth-copy h1 {
            margin: 0;
            font-family: 'Manrope', sans-serif;
            font-size: clamp(2rem, 7vw, 2.35rem);
            font-weight: 600;
            letter-spacing: -0.04em;
            color: #845b98;
        }

        html[data-theme='dark'] .auth-copy h1 {
            color: #f1e4f7;
        }

        .auth-copy p {
            margin: 0;
            color: var(--muted);
            font-size: 0.95rem;
            line-height: 1.55;
        }

        .alert {
            position: relative;
            z-index: 1;
            padding: 12px 14px;
            border-radius: 16px;
            background: var(--danger-bg);
            color: var(--danger-text);
            font-size: 0.92rem;
            text-align: center;
        }

        .form {
            position: relative;
            z-index: 1;
            display: grid;
            gap: 12px;
        }

        .form-item {
            display: grid;
            gap: 8px;
        }

        .sr-only {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0, 0, 0, 0);
            white-space: nowrap;
            border: 0;
        }

        .input-shell {
            position: relative;
        }

        .field-icon,
        .btn-eye {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            color: #b5a8b8;
        }

        .field-icon {
            left: 16px;
            width: 20px;
            height: 20px;
            pointer-events: none;
        }

        .btn-eye {
            right: 14px;
            width: 28px;
            height: 28px;
            border: 0;
            background: transparent;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0;
        }

        .btn-eye svg {
            width: 18px;
            height: 18px;
        }

        .btn-eye .eye-off {
            display: none;
        }

        .btn-eye.is-active .eye-on {
            display: none;
        }

        .btn-eye.is-active .eye-off {
            display: block;
        }

        .form input {
            width: 100%;
            height: 58px;
            border: 1px solid var(--input-border);
            border-radius: 14px;
            background: var(--input-bg);
            color: var(--text);
            padding: 0 50px 0 48px;
            font: inherit;
            font-size: 0.98rem;
            box-shadow: var(--field-shadow);
            outline: none;
            transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
        }

        .form input::placeholder {
            color: #b7afb7;
        }

        .form input:focus {
            border-color: rgba(177, 132, 201, 0.72);
            box-shadow: 0 14px 24px rgba(126, 95, 149, 0.2);
            transform: translateY(-1px);
        }

        .auth-btn {
            margin-top: 8px;
            width: 100%;
            height: 56px;
            border: 0;
            border-radius: 999px;
            background: linear-gradient(180deg, #b88ad0, #a978c4);
            color: var(--button-text);
            font: inherit;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            box-shadow: 0 14px 24px var(--button-shadow);
            transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
        }

        .auth-btn:hover {
            transform: translateY(-2px);
            filter: brightness(1.02);
            box-shadow: 0 18px 28px rgba(152, 112, 181, 0.4);
        }

        .auth-links {
            position: relative;
            z-index: 1;
            display: grid;
            justify-items: center;
            gap: 12px;
            padding-top: 4px;
        }

        .auth-links a,
        .auth-links span {
            color: #8f76a0;
            text-decoration: none;
            font-size: 0.98rem;
        }

        .auth-links a:hover {
            text-decoration: underline;
        }

        .auth-links .secondary-link {
            font-weight: 500;
        }

        .auth-links .register-link {
            font-weight: 600;
        }

        .bottom-flourish {
            position: relative;
            z-index: 1;
            height: 52px;
            margin-top: 4px;
        }

        .bottom-flourish::before,
        .bottom-flourish::after {
            content: '';
            position: absolute;
            inset: auto;
        }

        .bottom-flourish::before {
            left: 6px;
            bottom: 4px;
            width: 88px;
            height: 42px;
            background:
                radial-gradient(circle at 18% 60%, rgba(236, 198, 225, 0.92), transparent 24%),
                radial-gradient(circle at 36% 42%, rgba(241, 212, 231, 0.88), transparent 28%),
                radial-gradient(circle at 62% 78%, rgba(211, 223, 203, 0.82), transparent 26%);
            opacity: 0.8;
        }

        .bottom-flourish::after {
            right: 8px;
            bottom: 0;
            width: 86px;
            height: 36px;
            background:
                radial-gradient(circle at 22% 52%, rgba(253, 248, 241, 0.95), transparent 16%),
                radial-gradient(circle at 48% 52%, rgba(236, 220, 210, 0.96), transparent 20%),
                radial-gradient(circle at 72% 52%, rgba(220, 184, 233, 0.92), transparent 24%);
            opacity: 0.72;
        }

        @media (min-width: 720px) {
            body {
                padding: 24px;
            }

            .auth-shell {
                width: min(100%, 560px);
                min-height: auto;
            }

            .auth-card {
                padding: 38px 30px 32px;
            }
        }
    </style>
</head>
<body>
    <button class="theme-toggle" data-theme-btn aria-label="Cambiar tema">
        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"></circle>
            <path d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"></path>
        </svg>
        <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"></path>
        </svg>
    </button>

    <main class="auth-shell">
        <section class="auth-card">
            <div class="brand">
                <div class="brand-bloom" aria-hidden="true">
                    <span></span>
                    <span></span>
                </div>
                <img src="/brand/logo.png" alt="SaleySpa">
            </div>

            <header class="auth-copy">
                <h1>Iniciar Sesión</h1>
                <p>Accede con tus credenciales de SaleySpa.</p>
            </header>

            <% if (error) { %>
                <div class="alert"><%= error %></div>
            <% } %>

            <form action="/login" method="POST" class="form">
                <div class="form-item">
                    <label class="sr-only" for="email">Correo electrónico</label>
                    <div class="input-shell">
                        <svg class="field-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M4 6h16v12H4z"></path>
                            <path d="m4 8 8 6 8-6"></path>
                        </svg>
                        <input
                            type="email"
                            id="email"
                            name="email"
                            value="<%= typeof email !== 'undefined' ? email : '' %>"
                            required
                            placeholder="Correo electrónico"
                            autocomplete="email"
                        >
                    </div>
                </div>

                <div class="form-item">
                    <label class="sr-only" for="password">Contraseña</label>
                    <div class="input-shell">
                        <svg class="field-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <rect x="5" y="11" width="14" height="9" rx="2"></rect>
                            <path d="M8 11V8a4 4 0 0 1 8 0v3"></path>
                        </svg>
                        <input
                            type="password"
                            id="password"
                            name="password"
                            required
                            placeholder="Contraseña"
                            autocomplete="current-password"
                        >
                        <button class="btn-eye" type="button" data-eye-btn aria-label="Mostrar u ocultar contraseña">
                            <svg class="eye-on" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7S1 12 1 12z"></path>
                                <circle cx="12" cy="12" r="3"></circle>
                            </svg>
                            <svg class="eye-off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <path d="m2 2 20 20"></path>
                                <path d="M6.7 6.72A17.64 17.64 0 0 0 1 12s4 7 11 7a10.7 10.7 0 0 0 5.3-1.38"></path>
                                <path d="M10.58 10.59A2 2 0 0 0 13.41 13.4"></path>
                                <path d="M9.88 4.24A10.94 10.94 0 0 1 12 4c7 0 11 8 11 8a18.8 18.8 0 0 1-3.23 4.36"></path>
                            </svg>
                        </button>
                    </div>
                </div>

                <button class="auth-btn" type="submit">Iniciar Sesión</button>
            </form>

            <div class="auth-links">
                <span class="secondary-link">¿Olvidaste tu contraseña?</span>
                <a class="register-link" href="/register">Regístrate aquí</a>
            </div>

            <div class="bottom-flourish" aria-hidden="true"></div>
        </section>
    </main>

    <script>
        const root = document.documentElement;
        const themeBtn = document.querySelector('[data-theme-btn]');
        const passwordInput = document.getElementById('password');
        const eyeBtn = document.querySelector('[data-eye-btn]');

        themeBtn.onclick = () => {
            const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
            root.dataset.theme = next;
            localStorage.setItem('saleyspa-theme', next);
        };

        eyeBtn.onclick = () => {
            const isPassword = passwordInput.type === 'password';
            passwordInput.type = isPassword ? 'text' : 'password';
            eyeBtn.classList.toggle('is-active', isPassword);
        };
    </script>
</body>
</html>
