<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SaleySpa – Movimientos</title>
    <link rel="stylesheet" href="/css/styleNav.css">
    <link rel="stylesheet" href="/css/styleMovements.css">
</head>
<body>

<%- include('../partials/navbar') %>

<div class="container">
    <div class="list-card">
        <div class="list-header">
            <h2 class="card-title">Movimientos</h2>
            <a href="/movements/new" class="btn-primary">Nuevo movimiento</a>
        </div>

        <!-- Filtros -->
        <form action="/movements" method="GET" class="filters">
            <div class="filter-item">
                <label for="start">Desde</label>
                <input type="date" id="start" name="start" value="<%= (filters && filters.start) || '' %>">
            </div>
            <div class="filter-item">
                <label for="end">Hasta</label>
                <input type="date" id="end" name="end" value="<%= (filters && filters.end) || '' %>">
            </div>
            <button type="submit" class="btn-secondary">Filtrar</button>
            <a class="btn-link" href="/movements">Limpiar</a>
        </form>

        <% if (movements.length === 0) { %>
            <p class="empty-state">No hay movimientos registrados.</p>
        <% } else { %>
            <table class="table table-striped table-hover">
                <thead>
                <tr>
                    <th>Fecha</th>
                    <th>Tipo</th>
                    <th>Valor</th>
                    <th>Pago</th>
                    <th>Categoría</th>
                    <th>Descripción</th>
                    <th>Acciones</th>
                </tr>
                </thead>
                <tbody>
                <% movements.forEach(mov => { %>
                    <tr>
                        <td><%= (mov.date instanceof Date ? mov.date.toISOString().split('T')[0] : mov.date) %></td>
                        <td><%= mov.type === 'gasto' ? 'Gasto' : 'Ingreso' %></td>
                        <td>$<%= Number(mov.amount).toLocaleString('es-CO') %></td>
                        <td><%= mov.payment_type %></td>
                        <td><%= mov.category %></td>
                        <td><%= mov.description %></td>
                        <td>
                            <a href="/movements/<%= mov.id %>/edit" class="btn-secondary btn-sm">Editar</a>
                            <form action="/movements/<%= mov.id %>?_method=DELETE" method="POST" style="display:inline;">
                                <button class="btn-danger btn-sm" onclick="return confirm('¿Borrar este movimiento?')">Borrar</button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
                </tbody>
            </table>

            <!-- ✅ Paginación debajo de la tabla (usa DIV, no NAV) -->
            <% if (pagination && pagination.totalPages > 1) { %>
                <div class="pagination">
                    <%
                        const q = new URLSearchParams();
                        if (filters && filters.start) q.set('start', filters.start);
                        if (filters && filters.end)   q.set('end', filters.end);
                        function linkTo(p) {
                            const qp = new URLSearchParams(q.toString());
                            qp.set('page', String(p));
                            return '/movements?' + qp.toString();
                        }
                        const p  = pagination.page;
                        const tp = pagination.totalPages;
                    %>

                    <% if (p > 1) { %>
                        <a class="btn-secondary" href="<%= linkTo(p - 1) %>">« Anterior</a>
                    <% } else { %>
                        <span class="btn-secondary disabled">« Anterior</span>
                    <% } %>

                    <% for (let i = 1; i <= tp; i++) { %>
                        <% if (i === p) { %>
                            <span class="btn-primary current"><%= i %></span>
                        <% } else { %>
                            <a class="btn-secondary" href="<%= linkTo(i) %>"><%= i %></a>
                        <% } %>
                    <% } %>

                    <% if (p < tp) { %>
                        <a class="btn-secondary" href="<%= linkTo(p + 1) %>">Siguiente »</a>
                    <% } else { %>
                        <span class="btn-secondary disabled">Siguiente »</span>
                    <% } %>
                </div>
            <% } %>
        <% } %>
    </div>
</div>

<footer class="footer">
    <div class="footer-container">
        <p>© <%= new Date().getFullYear() %> SaleySpa. Todos los derechos reservados.</p>
    </div>
</footer>

</body>
</html>
