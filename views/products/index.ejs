<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Productos</title>

    <link rel="stylesheet" href="/css/styleClients.css">
    <link rel="stylesheet" href="/css/styleNav.css"><!-- menú -->
</head>
<body>

<!-- NAVBAR -->
<nav>
    <div class="logo">SaleySpa</div>

    <button id="burger" class="hamburger" aria-label="Menú">
        <span></span><span></span><span></span>
    </button>

    <aside id="nav-menu" class="nav-menu">
        <a href="/">Inicio</a>
        <a href="/clients">Clientes</a>
        <a href="/products">Productos</a>
        <a href="/sales">Ventas</a>
        <a href="/logout">Salir</a>
    </aside>
</nav>

<div class="container">
    <h1>Productos</h1>

    <div class="actions">
        <a href="/products/new" class="btn new-client">+ Nuevo Producto</a>
    </div>

    <% if (error) { %><p class="error"><%= error %></p><% } %>

    <table class="clients-table">
        <thead>
        <tr><th>Nombre</th><th>Precio ($)</th><th>Acciones</th></tr>
        </thead>
        <tbody>
        <% if (!products.length) { %>
            <tr><td colspan="3" class="text-center">No hay productos.</td></tr>
        <% } else { products.forEach(p => { %>
            <tr>
                <td><%= p.name %></td>
                <td>$<%= Number(p.price).toLocaleString('es-CO',{minimumFractionDigits:0}) %></td>
                <td class="text-center">
                    <a href="/products/<%= p.hash %>/edit" class="edit-btn">Editar</a>
                </td>
            </tr>
        <% }) } %>
        </tbody>
    </table>
</div>

<!-- script menú -->
<script>
    const b = document.getElementById('burger');
    const m = document.getElementById('nav-menu');
    b.onclick = ()=>{ b.classList.toggle('active'); m.classList.toggle('active'); };
    document.addEventListener('click',e=>{
        if(!m.contains(e.target)&&!b.contains(e.target)){
            b.classList.remove('active'); m.classList.remove('active');
        }
    });
</script>
</body>
</html>
