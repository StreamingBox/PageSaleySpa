<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>SaleySpa – Categorías</title>

    <!-- CSS navegación -->
    <link rel="stylesheet" href="/css/styleNav.css">
    <!-- CSS global (botones, tablas, etc.) -->
    <link rel="stylesheet" href="/css/styleMovements.css">
    <!-- CSS específico de categorías -->
    <link rel="stylesheet" href="/css/styleCategories.css">
</head>
<body>

<nav class="site-nav">
    <div class="nav-container">
        <a href="/"           class="nav-link">Inicio</a>
        <a href="/clients"    class="nav-link">Clientes</a>
        <a href="/products"   class="nav-link">Productos</a>
        <a href="/sales"      class="nav-link">Ventas</a>
        <a href="/movements"  class="nav-link">Movimientos</a>
        <a href="/categories" class="nav-link active">Categorías</a>
        <a href="/logout"     class="nav-link">Salir</a>
    </div>
</nav>

<div class="container">
    <div class="list-card">
        <div class="list-header">
            <h2 class="card-title">Categorías</h2>
            <a href="/categories/new" class="btn-primary">Nueva categoría</a>
        </div>

        <% if (categories.length === 0) { %>
            <p class="empty-state">Aún no hay categorías registradas.</p>
        <% } else { %>
            <table class="table table-striped table-hover">
                <thead>
                <tr>
                    <th>Nombre</th>
                    <th class="text-end">Acciones</th>
                </tr>
                </thead>
                <tbody>
                <% categories.forEach(c => { %>
                    <tr>
                        <td><%= c.name %></td>
                        <td class="text-end">
                            <a href="/categories/<%= c.id %>/edit" class="btn-secondary btn-sm">Editar</a>

                            <form action="/categories/<%= c.id %>/delete"
                                  method="POST"
                                  class="d-inline">
                                <button class="btn-danger btn-sm"
                                        onclick="return confirm('¿Eliminar categoría?')">
                                    Borrar
                                </button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
                </tbody>
            </table>
        <% } %>
    </div>
</div>

<footer class="footer">
    <div class="footer-container">
        <p>© <%= new Date().getFullYear() %> SaleySpa. Todos los derechos reservados.</p>
    </div>
</footer>

</body>
</html>
